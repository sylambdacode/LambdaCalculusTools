{- use simplelang subcommand -}

main = cps {
    _ <- loop 1;
    _ <- print (concat "'fact(100) = " (tostring (fact 100)));
    _
};


loop = Y ^self. ^a. ^cont. cps {
    _ <- print (concat "'helloworld" (tostring a));
    if (eq a 100)
        (cont a)
        cps {
            _ <- self (add a 1);
            cont a
        }
};


fact = Y ^self. ^a.
    if (eq a 0)
        1
        (mul a (self (sub a 1)));

Y = (λu x. x (u u x)) (λu x. x (u u x));
